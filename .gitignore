# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
*.log

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Environment Variables - NEVER commit these to GitHub
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# But DO allow the example file so others know what keys they need
!.env.example

# vercel
.vercel

# turbopack / local caches
.turbo/

# test artifacts
playwright-report/
test-results/

# local editor/assistant state
.cursor/

# typescript
*.tsbuildinfo
next-env.d.ts
